FROM nvidia/cuda:13.2.0-devel-ubuntu24.04 AS build

RUN apt-get update && apt-get install -y \
    git cmake ninja-build build-essential \
    curl ca-certificates libcurl4-openssl-dev pkg-config

WORKDIR /src

RUN git clone https://github.com/ggml-org/llama.cpp .
RUN cmake -B build -G Ninja \
    -DGGML_CUDA=ON \
    -DGGML_CUDA_FORCE_MMQ=ON \
    -DCMAKE_CUDA_ARCHITECTURES=90 \
    -DLLAMA_BUILD_SERVER=ON \
    -DCMAKE_BUILD_TYPE=Release && \
    cmake --build build -j$(nproc)

FROM nvidia/cuda:13.2.0-runtime-ubuntu24.04

RUN apt-get update && apt-get install -y \
    libgomp1 libcurl4 ca-certificates curl

COPY --from=build /src/build/bin/llama-server /usr/local/bin/llama-server

ENV LD_LIBRARY_PATH=/usr/local/cuda/compat:/usr/local/lib

EXPOSE 8080

CMD ["llama-server"]